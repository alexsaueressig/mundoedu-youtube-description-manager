# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit real credentials.

# YouTube channel handle (without the @)
CHANNEL_HANDLE=portalmundoedu

# Path to the OAuth 2.0 client secrets file downloaded from Google Cloud Console.
# Default: client_secrets.json (in the project root)
CLIENT_SECRETS_FILE=client_secrets.json

# Path where the OAuth token will be cached after first login.
# Default: token.json (in the project root)
TOKEN_FILE=token.json

# Directory where fetched description Markdown files are stored.
# Default: videos/descriptions/
DESCRIPTIONS_DIR=videos/descriptions
